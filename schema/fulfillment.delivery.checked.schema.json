{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "fulfillment.delivery.checked",
  "title": "fulfillment.delivery.checked",
  "description": "Delivery availability has been checked for a buyer address. Produced by the Post-Auction & Fulfillment Service (4).",
  "type": "object",
  "additionalProperties": false,
  "required": ["eventId", "sessionId", "basketId", "buyerId", "address", "deliveryAvailable", "reason", "occurredAt"],
  "properties": {
    "eventName": { "type": "string", "description": "Optional self-describing event type; equals the topic name. Not required." },
    "eventId": { "type": "string", "format": "uuid" },
    "sessionId": { "type": "string", "minLength": 1 },
    "basketId": { "type": "string", "minLength": 1 },
    "buyerId": { "type": "string", "minLength": 1 },
    "address": { "type": "string", "minLength": 1 },
    "deliveryAvailable": { "type": "boolean" },
    "reason": { "type": "string", "enum": ["NEARBY_ADDRESS", "OUT_OF_DELIVERY_AREA", "ADDRESS_MISSING"] },
    "occurredAt": { "type": "string", "format": "date-time" }
  }
}
