# Post-Auction & Fulfillment Service — environment template.
# Copy to `.env` and fill in real values. `.env` is git-ignored.

# HTTP server port. Default 3000; can be changed via PORT env.
PORT=3000

# PostgreSQL (Post-Auction private DB)
PGHOST=
PGPORT=5432
PGDATABASE=post_auction_service
PGUSER=postgres
PGPASSWORD=

# Kafka / Confluent Cloud
KAFKA_BROKERS=
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
KAFKA_GROUP_ID=post-auction-service-local
KAFKA_CLIENT_ID=post-auction-service
