{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "fulfillment.basket.completed",
  "title": "fulfillment.basket.completed",
  "description": "Post-auction fulfillment has been completed for a basket. Produced by the Post-Auction & Fulfillment Service (4).",
  "type": "object",
  "additionalProperties": false,
  "required": ["eventId", "sessionId", "basketId", "buyerId", "fulfillmentStatus", "deliveryAvailable", "occurredAt"],
  "properties": {
    "eventName": { "type": "string", "description": "Optional self-describing event type; equals the topic name. Not required." },
    "eventId": { "type": "string", "format": "uuid" },
    "sessionId": { "type": "string", "minLength": 1 },
    "basketId": { "type": "string", "minLength": 1 },
    "buyerId": { "type": "string", "minLength": 1 },
    "fulfillmentStatus": { "type": "string", "enum": ["COMPLETED"] },
    "deliveryAvailable": { "type": "boolean" },
    "occurredAt": { "type": "string", "format": "date-time" }
  }
}
