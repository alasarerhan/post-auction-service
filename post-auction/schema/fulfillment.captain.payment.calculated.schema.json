{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "fulfillment.captain.payment.calculated",
  "title": "fulfillment.captain.payment.calculated",
  "description": "Per-captain payout for an auction session: how many baskets were sold and the total amount owed. Produced by the Post-Auction & Fulfillment Service (4).",
  "type": "object",
  "additionalProperties": false,
  "required": ["eventId", "sessionId", "boatName", "soldBasketCount", "totalAmount", "occurredAt"],
  "properties": {
    "eventName": { "type": "string", "description": "Optional self-describing event type; equals the topic name. Not required." },
    "eventId": { "type": "string", "format": "uuid" },
    "sessionId": { "type": "string", "minLength": 1 },
    "memberId": { "type": "string", "minLength": 1 },
    "boatName": { "type": "string", "minLength": 1 },
    "soldBasketCount": { "type": "integer", "minimum": 0 },
    "totalAmount": { "type": "number", "minimum": 0 },
    "occurredAt": { "type": "string", "format": "date-time" }
  }
}
