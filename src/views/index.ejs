<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>BID Service</title>
    <style>
      body {
        font-family: Arial, sans-serif;
        margin: 2rem;
        background: #f6f8fb;
        color: #1d2939;
      }
      .card {
        background: #ffffff;
        border-radius: 12px;
        padding: 1.5rem;
        margin-bottom: 1rem;
        box-shadow: 0 8px 24px rgba(15, 23, 42, 0.08);
      }
      a {
        color: #0057b8;
        text-decoration: none;
      }
      table {
        width: 100%;
        border-collapse: collapse;
      }
      th, td {
        padding: 0.75rem;
        border-bottom: 1px solid #e5e7eb;
        text-align: left;
      }
    </style>
  </head>
  <body data-page="home" data-snapshot-token="<%= snapshotToken %>">
    <div id="liveBanner" class="card" style="display: none;">Live update received. Refreshing view...</div>
    <div class="card">
      <h2>Auction Sessions</h2>
      <% if (!sessions.length) { %>
        <p>No local auction sessions yet. Waiting for real Kafka catalog events from other services.</p>
      <% } else { %>
        <table>
          <thead>
            <tr>
              <th>Session</th>
              <th>Title</th>
              <th>Status</th>
              <th>Baskets</th>
            </tr>
          </thead>
          <tbody>
            <% sessions.forEach((session) => { %>
              <tr>
                <td><a href="/auction/<%= session.session_id %>"><%= session.session_id %></a></td>
                <td><%= session.title %></td>
                <td><%= session.status %></td>
                <td><%= session.basket_count %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </div>

    <script src="/socket.io/socket.io.js"></script>
    <script src="/main.js"></script>
  </body>
</html>
